# Copy this file to .env for local development. Never distribute your real .env.

# Server
COMPANION_HOST=127.0.0.1
COMPANION_PORT=5000
COMPANION_API_KEY=
CORS_ORIGINS=http://localhost:30000,http://127.0.0.1:30000
COMPANION_DATA_DIR=./data

# RAG / Memory
RAG_COLLECTION_NAME=bgh_world_rag
MEMORY_COLLECTION_NAME=bgh_npc_memories

# Optional Vertex AI OpenAI-compatible proxy
# Use the Google Cloud project ID, not the display name.
# If left blank, the server also accepts GOOGLE_CLOUD_PROJECT, GCLOUD_PROJECT, PROJECT_ID,
# or the default project from Google Application Default Credentials.
VERTEX_PROJECT_ID=
VERTEX_REGION=global
# Optional. Usually same as VERTEX_PROJECT_ID. Helps silence Google ADC quota-project warnings.
VERTEX_QUOTA_PROJECT_ID=

# Optional "proxy mode" — keep LLM provider API keys server-side so the Foundry module
# never ships them to the browser. Set the key(s) for the providers you use, then point
# the module's model base URL at http://127.0.0.1:5000/llm/<provider> (proxy mode in the
# Settings Hub). google uses the Gemini API (AI Studio), not Vertex. Each upstream base
# URL is overridable via LLM_PROXY_<PROVIDER>_BASE_URL.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Local STT. In a dev checkout: install requirements-stt.txt first, then set
# STT_ENABLED=true (PyAV-bundled decoder, no system ffmpeg needed). In the frozen
# bundle STT defaults ON and ships the Whisper CT2 model under models/ (loaded offline
# by _resolve_local_stt_ref), so no first-run download.
STT_ENABLED=false
STT_MODEL=large-v3-turbo
# HF repo of the CT2 Whisper model bundled for offline use (also what
# fetch_local_model.py downloads). The concrete repo behind the large-v3-turbo alias.
STT_HF_REPO=mobiuslabsgmbh/faster-whisper-large-v3-turbo
# Force a specific local Whisper model directory (overrides the bundled snapshot and
# the alias). Leave blank to auto-resolve the bundled snapshot (frozen) or download
# the alias (dev).
STT_MODEL_PATH=
STT_DEVICE=cpu
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=ko

# Optional local embedding fallback (open-weight voyage-4-nano). Lets the server
# embed WITHOUT a Voyage API key. Install requirements-local-embed.txt first (pulls
# CPU torch). Defaults ON in the frozen bundle (which ships the model); OFF here.
# When a Voyage API key is supplied, Voyage always wins regardless of this flag.
LOCAL_EMBEDDING_ENABLED=false
LOCAL_EMBEDDING_MODEL=voyageai/voyage-4-nano
# Leave blank to auto-resolve a bundled snapshot (frozen build) or download the
# model id above (dev). Set to an existing directory to force a specific snapshot.
LOCAL_EMBEDDING_MODEL_PATH=
LOCAL_EMBEDDING_DIMENSION=1024
LOCAL_EMBEDDING_DEVICE=cpu

# Legacy data migration helpers. The old local proxy used these collection names.
# They are only used by migrate_legacy_data.py and status diagnostics.
LEGACY_RAG_COLLECTION_NAME=legacy_rag
LEGACY_MEMORY_COLLECTION_NAME=legacy_npc_memories
